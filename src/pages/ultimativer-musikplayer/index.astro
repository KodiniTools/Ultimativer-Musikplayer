---
/**
 * Ultimativer Musikplayer – Landingpage (statisch, SEO-optimiert)
 * i18n via data-i18n Attribute, synchronisiert mit SSI-Navigation language-changed Event.
 * Übersetzungen kommen aus den gemeinsamen Locale-Dateien (Single Source of Truth).
 */
import '../../assets/styles/main.css'
import de from '../../components/vue/ultimativer-musikplayer/i18n/locales/de.js'
import en from '../../components/vue/ultimativer-musikplayer/i18n/locales/en.js'
const t = de
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#F5F4D6" />

  <title>Ultimativer Musikplayer – Kostenloser Online-Audioplayer | KodiniTools</title>
  <meta name="description" content="Kostenloser Online-Musikplayer mit 7 Audio-Visualisierungsmodi, Playlist-Management und Equalizer. Unterstützt MP3, WAV, FLAC, M4A, OGG. Keine Registrierung nötig." />
  <meta name="keywords" content="Musikplayer, Audio Visualizer, Online Player, MP3 Player, kostenlos, Equalizer, Playlist" />

  <!-- Sitemap -->
  <link rel="sitemap" type="application/xml" href="/ultimativer-musikplayer/sitemap.xml" />

  <!-- Open Graph -->
  <meta property="og:title" content="Ultimativer Musikplayer – KodiniTools" />
  <meta property="og:description" content="Erleben Sie Musik auf eine völlig neue Art mit fortschrittlicher Audio-Visualisierung, Playlist-Funktionen und modernem Design." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://kodinitools.com/ultimativer-musikplayer/" />

  <!-- Font Awesome (lokal) -->
  <link rel="stylesheet" href="/fontawesome/css/fontawesome.min.css" />
  <link rel="stylesheet" href="/fontawesome/css/solid.min.css" />

  <style>
    /* Landing-Page-spezifische Styles */
    .landing {
      max-width: 960px;
      margin: 0 auto;
      padding: clamp(20px, 4vw, 40px);
      display: grid;
      gap: 32px;
    }

    .hero {
      text-align: center;
      padding: 48px 28px;
      background: var(--glass-bg);
      backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid var(--glass-border);
      border-radius: 24px;
      box-shadow: var(--shadow-3d-lg);
    }

    .hero h1 {
      font-size: clamp(1.4rem, 3vw, 2rem);
      margin-bottom: 16px;
      -webkit-text-fill-color: unset;
      background: none;
      color: var(--heading-primary);
    }

    .hero p {
      font-size: 1rem;
      color: var(--text-secondary);
      max-width: 640px;
      margin: 0 auto 28px;
      line-height: 1.7;
    }

    .cta-button {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 32px;
      background: linear-gradient(135deg, var(--accent), var(--primary-dark, #003971));
      color: #F5F4D6;
      text-decoration: none;
      border-radius: 14px;
      font-weight: 700;
      font-size: 1rem;
      box-shadow: var(--shadow-3d-md), var(--glow-accent);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .cta-button:hover {
      transform: translateY(-4px) translateZ(10px);
      box-shadow: var(--shadow-3d-lg), var(--glow-accent);
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px;
    }

    .feature-card {
      padding: 24px;
      background: var(--glass-bg);
      backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid var(--glass-border);
      border-radius: 18px;
      box-shadow: var(--shadow-3d-sm);
      transition: all 0.3s ease;
    }

    .feature-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-3d-md);
    }

    .feature-card i {
      font-size: 1.6rem;
      margin-bottom: 12px;
      display: block;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .feature-card h3 {
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 8px;
      color: var(--heading-primary);
    }

    .feature-card p {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .section-title {
      font-size: 1.2rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 24px;
      background: linear-gradient(135deg, var(--heading-gradient-start), var(--heading-gradient-end));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* FAQ auf Landing Page */
    .landing .faq-item {
      margin-bottom: 16px;
      border: 1px solid var(--glass-border);
      border-radius: 14px;
      overflow: hidden;
      background: var(--glass-bg);
      backdrop-filter: blur(10px);
      box-shadow: var(--shadow-3d-sm);
    }

    .landing .faq-question {
      width: 100%;
      padding: 14px 18px;
      background: transparent;
      border: none;
      text-align: left;
      cursor: pointer;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      font-family: inherit;
    }

    .landing .faq-answer {
      padding: 0 18px;
      max-height: 0;
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .landing .faq-answer.open {
      padding: 14px 18px;
      max-height: 400px;
    }

    .landing .faq-answer p {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .landing .faq-icon {
      color: var(--primary);
      transition: transform 0.3s ease;
    }

    .landing .faq-icon.open {
      transform: rotate(180deg);
    }

    @media (max-width: 480px) {
      .hero {
        padding: 32px 18px;
      }
      .hero h1 {
        font-size: 1.2rem;
      }
      .cta-button {
        padding: 12px 24px;
        font-size: 0.9rem;
      }
    }
  </style>
</head>
<body>
  <!--#include virtual="/partials/nav.html" -->

  <main class="landing">
    <!-- Hero Section -->
    <section class="hero">
      <h1 data-i18n="hero.title">{t.hero.title}</h1>
      <p data-i18n="hero.desc">{t.hero.desc}</p>
      <a href="/ultimativer-musikplayer/app" class="cta-button">
        <i class="fa-solid fa-play"></i>
        <span data-i18n="hero.cta">{t.hero.cta}</span>
      </a>
    </section>

    <!-- Hauptfeatures -->
    <section>
      <h2 class="section-title" data-i18n="features.title">{t.features.title}</h2>
      <div class="features-grid">
        <div class="feature-card">
          <i class="fa-solid fa-wave-square"></i>
          <h3 data-i18n="features.viz.title">{t.features.viz.title}</h3>
          <p data-i18n="features.viz.desc">{t.features.viz.desc}</p>
        </div>

        <div class="feature-card">
          <i class="fa-solid fa-sliders"></i>
          <h3 data-i18n="features.eq.title">{t.features.eq.title}</h3>
          <p data-i18n="features.eq.desc">{t.features.eq.desc}</p>
        </div>

        <div class="feature-card">
          <i class="fa-solid fa-list"></i>
          <h3 data-i18n="features.playlist.title">{t.features.playlist.title}</h3>
          <p data-i18n="features.playlist.desc">{t.features.playlist.desc}</p>
        </div>

        <div class="feature-card">
          <i class="fa-solid fa-mobile-screen"></i>
          <h3 data-i18n="features.responsive.title">{t.features.responsive.title}</h3>
          <p data-i18n="features.responsive.desc">{t.features.responsive.desc}</p>
        </div>

        <div class="feature-card">
          <i class="fa-solid fa-circle-half-stroke"></i>
          <h3 data-i18n="features.theme.title">{t.features.theme.title}</h3>
          <p data-i18n="features.theme.desc">{t.features.theme.desc}</p>
        </div>

        <div class="feature-card">
          <i class="fa-solid fa-lock"></i>
          <h3 data-i18n="features.free.title">{t.features.free.title}</h3>
          <p data-i18n="features.free.desc">{t.features.free.desc}</p>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="content-section">
      <h2 class="section-title" data-i18n="faq.title">{t.faq.title}</h2>

      <div class="faq-item">
        <button class="faq-question" onclick="this.nextElementSibling.classList.toggle('open'); this.querySelector('.faq-icon').classList.toggle('open')">
          <span data-i18n="faq.formats.question">{t.faq.formats.question}</span>
          <i class="fa-solid fa-chevron-down faq-icon"></i>
        </button>
        <div class="faq-answer">
          <p data-i18n="faq.formats.answer">{t.faq.formats.answer}</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" onclick="this.nextElementSibling.classList.toggle('open'); this.querySelector('.faq-icon').classList.toggle('open')">
          <span data-i18n="faq.free.question">{t.faq.free.question}</span>
          <i class="fa-solid fa-chevron-down faq-icon"></i>
        </button>
        <div class="faq-answer">
          <p data-i18n="faq.free.answer">{t.faq.free.answer}</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" onclick="this.nextElementSibling.classList.toggle('open'); this.querySelector('.faq-icon').classList.toggle('open')">
          <span data-i18n="faq.visualization.question">{t.faq.visualization.question}</span>
          <i class="fa-solid fa-chevron-down faq-icon"></i>
        </button>
        <div class="faq-answer">
          <p data-i18n="faq.visualization.answer">{t.faq.visualization.answer}</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" onclick="this.nextElementSibling.classList.toggle('open'); this.querySelector('.faq-icon').classList.toggle('open')">
          <span data-i18n="faq.mobile.question">{t.faq.mobile.question}</span>
          <i class="fa-solid fa-chevron-down faq-icon"></i>
        </button>
        <div class="faq-answer">
          <p data-i18n="faq.mobile.answer">{t.faq.mobile.answer}</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" onclick="this.nextElementSibling.classList.toggle('open'); this.querySelector('.faq-icon').classList.toggle('open')">
          <span data-i18n="faq.privacy.question">{t.faq.privacy.question}</span>
          <i class="fa-solid fa-chevron-down faq-icon"></i>
        </button>
        <div class="faq-answer">
          <p data-i18n="faq.privacy.answer">{t.faq.privacy.answer}</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" onclick="this.nextElementSibling.classList.toggle('open'); this.querySelector('.faq-icon').classList.toggle('open')">
          <span data-i18n="faq.upload_limit.question">{t.faq.upload_limit.question}</span>
          <i class="fa-solid fa-chevron-down faq-icon"></i>
        </button>
        <div class="faq-answer">
          <p data-i18n="faq.upload_limit.answer">{t.faq.upload_limit.answer}</p>
        </div>
      </div>
    </section>

    <!-- CTA Bottom -->
    <section class="hero" style="padding: 32px 28px;">
      <p style="margin-bottom: 20px;" data-i18n="cta.text">{t.cta.text}</p>
      <a href="/ultimativer-musikplayer/app" class="cta-button">
        <i class="fa-solid fa-headphones"></i>
        <span data-i18n="cta.button">{t.cta.button}</span>
      </a>
    </section>
  </main>

  <!--#include virtual="/partials/footer.html" -->
  <!--#include virtual="/partials/cookie-banner.html" -->

  <script define:vars={{ translations: { de, en } }}>
    (function () {
      function get(obj, path) {
        return path.split('.').reduce(function (o, k) { return o && o[k] }, obj)
      }

      function applyLang(lang) {
        var strings = translations[lang] || translations.de
        var elements = document.querySelectorAll('[data-i18n]')
        for (var i = 0; i < elements.length; i++) {
          var key = elements[i].getAttribute('data-i18n')
          var val = get(strings, key)
          if (val) elements[i].textContent = val
        }
        document.documentElement.lang = lang
      }

      var saved = localStorage.getItem('locale') || 'de'
      if (saved !== 'de') applyLang(saved)

      document.addEventListener('click', function (e) {
        var btn = e.target.closest('.global-nav-lang-btn')
        if (!btn) return
        var lang = btn.getAttribute('data-lang')
        if (lang) applyLang(lang)
      })

      window.addEventListener('locale-changed', function (e) {
        var lang = e.detail && e.detail.locale
        if (lang) applyLang(lang)
      })
    })()
  </script>
</body>
</html>